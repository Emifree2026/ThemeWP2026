{
  "name": "emifree-theme",
  "version": "1.0.0",
  "private": true,
  "description": "Custom WordPress theme for the Emifree GmbH air-filtration landing page.",
  "scripts": {
    "build": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/main.css --minify",
    "watch": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/main.css --watch",
    "dev": "npm run watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}